---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "krya" } = Astro.props;

// 导入 CSS 文件（Vite 会自动打包）
import '../styles/grid.css';
import '../styles/style.css';
---

<!DOCTYPE html>
<html lang="zh-Hans-CN">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1" />
    <meta name="renderer" content="webkit" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    
    <!-- Canonical URL (文章页会覆盖) -->
    <link rel="canonical" href={`https://krya.com${Astro.url.pathname}`} />
    
    <!-- 插入额外 head 内容（如 OG meta） -->
    <slot name="head" />
    
    <!-- CSS (imported for Vite bundling) -->
    
    <!-- 主题初始化 - 防止暗黑模式闪白 -->
    <script is:inline>
      (function() {
        const html = document.documentElement;
        
        /**
         * 设置主题
         */
        function setTheme(theme) {
          if (theme === 'dark') {
            html.setAttribute('data-theme', 'dark');
            html.style.colorScheme = 'dark';
          } else {
            html.removeAttribute('data-theme');
            html.style.colorScheme = 'light';
          }
          localStorage.setItem('theme', theme);
        }
        
        /**
         * 获取当前主题
         */
        function getTheme() {
          return localStorage.getItem('theme') || 
                 (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        }
        
        /**
         * 切换主题
         */
        function toggleTheme() {
          const current = html.getAttribute('data-theme');
          const newTheme = current === 'dark' ? 'light' : 'dark';
          setTheme(newTheme);
          return newTheme;
        }
        
        // 暴露到全局
        window.ThemeManager = { setTheme, getTheme, toggleTheme };
        
        // 自动初始化
        const theme = getTheme();
        setTheme(theme);
      })();
    </script>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="krya" href="/rss.xml" />
  </head>
  <body>
    <slot name="header" />
    
    <div id="body">
      <div class="container">
        <div class="colgroup">
          <slot />
        </div>
      </div>
    </div>
    
    <footer id="footer" role="contentinfo">
      © 2008-{new Date().getFullYear()}. Astro & <a href="https://github.com/ezzty/astro-sintu-theme" target="_blank" rel="noopener noreferrer" class="footer-link">Sintu Theme</a>
      <br />
      Stay Young ♥️ Stay Simple
      <div class="footer-social">
        <a href="/rss.xml" class="footer-link" title="RSS 订阅">RSS</a>
        <span class="footer-divider">|</span>
        <a href="https://en.krya.com/" class="footer-link" title="English Version">English</a>
      </div>
    </footer>
    
    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="9f0742ab-e931-4ae5-a978-6e0c611cc1b8"></script>
    
    <!-- Main JS -->
    <script src="/js/main.js" is:inline></script>
  </body>
</html>
