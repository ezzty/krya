---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Jin 的个人博客" } = Astro.props;

// 导入 CSS 文件（Vite 会自动打包）
import '../styles/normalize.css';
import '../styles/grid.css';
import '../styles/style.css';
---

<!DOCTYPE html>
<html lang="zh-Hans-CN">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge, chrome=1" />
    <meta name="renderer" content="webkit" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://blog.frc.cc" />
    <meta property="og:image" content="https://blog.frc.cc/og-image.png" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://blog.frc.cc/og-image.png" />
    
    <!-- Canonical URL (文章页会覆盖) -->
    <link rel="canonical" href={`https://blog.frc.cc${Astro.url.pathname}`} />
    
    <!-- CSS (imported for Vite bundling) -->
    
    <!-- 暗黑模式初始化 - 在 CSS 加载后，body 渲染前执行，防止闪白 -->
    <script is:inline>
      (function() {
        const html = document.documentElement;
        
        // 优先级：localStorage > 系统偏好
        let theme = localStorage.getItem('theme');
        
        if (!theme) {
          // 没有保存的值时，才用系统偏好，并保存到 localStorage
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          localStorage.setItem('theme', theme);
        }
        
        if (theme === 'dark') {
          html.setAttribute('data-theme', 'dark');
          html.style.colorScheme = 'dark';
        } else {
          html.removeAttribute('data-theme');
          html.style.colorScheme = 'light';
        }
      })();
    </script>
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="浮生百记 | Jin 的个人博客" href="/rss.xml" />
  </head>
  <body>
    <slot name="header" />
    
    <div id="body">
      <div class="container">
        <div class="colgroup">
          <slot />
        </div>
      </div>
    </div>
    
    <footer id="footer" role="contentinfo">
      © 2008-{new Date().getFullYear()}. Astro & <a href="https://github.com/ezzty/astro-sintu-theme" target="_blank" rel="noopener noreferrer" class="footer-link">Sintu Theme</a>
      <br />
      Stay Young ♥️ Stay Simple
      <div class="footer-social">
        <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="social-link" title="RSS 订阅">
          <span class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.1 10.888a1.811 1.811 0 0 1 .002 2.563H3.1c-.33.331-.782.531-1.284.531s-.953-.201-1.283-.531a1.807 1.807 0 0 1 0-2.563 1.811 1.811 0 0 1 2.567 0zm0 0h.001H3.1zM.533 13.451c-.001 0-.001 0 0 0zM.001 4.952V7.57a6.358 6.358 0 0 1 4.525 1.885 6.405 6.405 0 0 1 1.876 4.541V14h2.622a9.038 9.038 0 0 0-2.647-6.393A8.988 8.988 0 0 0 .001 4.952zM.006.291v2.617C6.1 2.911 11.054 7.886 11.058 14h2.618a13.694 13.694 0 0 0-4.011-9.688A13.609 13.609 0 0 0 .006.291z"/>
            </svg>
          </span>
        </a>
      </div>
    </footer>
    
    <!-- Main JS -->
    <script src="/js/main.js" is:inline></script>
  </body>
</html>
