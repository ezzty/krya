---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';

interface Post {
  title: string;
  slug: string;
  author: string;
  pubDate: string;
  wordCount: number;
  excerpt: string;
  thumbnail?: string;
}

interface Props {
  posts: Post[];
  currentPage?: number;
  totalPages?: number;
}

const { posts, currentPage = 1, totalPages = 1 } = Astro.props;

const formatDate = (date: string) => {
  return new Date(date).toISOString().split('T')[0];
};

// 截取摘要（减少 4 个字符）
const truncateExcerpt = (excerpt: string, length: number = 116) => {
  if (!excerpt) return '';
  return excerpt.slice(0, length);
};

// 生成页码列表（最多显示 5 个页码）
function getPageNumbers(current: number, total: number): number[] {
  if (total <= 5) {
    // 总页数 <= 5，显示所有页码
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  
  if (current <= 3) {
    // 当前页在前 3 页，显示 1-5
    return [1, 2, 3, 4, 5];
  }
  
  if (current >= total - 2) {
    // 当前页在后 3 页，显示最后 5 页
    return [total - 4, total - 3, total - 2, total - 1, total];
  }
  
  // 当前页在中间，显示当前页前后各 2 页
  return [current - 2, current - 1, current, current + 1, current + 2];
}

const pageNumbers = getPageNumbers(currentPage, totalPages);
---

<BaseLayout title="浮生百记 | 首页">
  <NavBar slot="header" />
  
  <div class="col-mb-12" id="main" role="main">
    {posts.map((post) => (
      <article class="post">
        <div class="col-3 index-image">
          <picture>
            <source 
              media="(min-width: 800px)" 
              srcset={(post.thumbnail || '/images/default-thumbnail.png') + ' 140w'}
              sizes="140px"
            />
            <img 
              class="thumbnail" 
              src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
              alt={post.title}
              width="140"
              height="140"
              decoding="async"
              loading="lazy"
            />
          </picture>
        </div>
        <h1 class="col-9 post-title">
          <a href={`/post/${post.slug}`}>{post.title}</a>
        </h1>
        <ul class="col-9 post-meta">
          <li>作者：<a href="/about">{post.author}</a></li>
          <li>{formatDate(post.pubDate)}</li>
          <li>{post.wordCount}字</li>
        </ul>
        <div class="col-9 post-content">
          {truncateExcerpt(post.excerpt)}...
        </div>
      </article>
    ))}
    
    {totalPages > 1 && (
      <nav class="pagination">
        <ul class="page-list">
          {/* 上一页 */}
          {currentPage > 1 && (
            <li class="page-item">
              <a href="/" class="page-link">&laquo; 上页</a>
            </li>
          )}
          
          {/* 页码列表 */}
          {pageNumbers.map((page) => (
            <li class="page-item">
              <a 
                href={page === 1 ? '/' : `/p/${page}`} 
                class={`page-link ${page === currentPage ? 'active' : ''}`}
              >
                {page}
              </a>
            </li>
          ))}
          
          {/* 下一页 */}
          {currentPage < totalPages && (
            <li class="page-item">
              <a href={`/p/${currentPage + 1}`} class="page-link">下页 &raquo;</a>
            </li>
          )}
        </ul>
      </nav>
    )}
  </div>
</BaseLayout>

<style>
  /* 首页缩略图 hover 放大效果 */
  .index-image {
    overflow: hidden;
    border-radius: 12px;
  }
  
  .index-image picture,
  .index-image img.thumbnail {
    width: 140px;
    height: 140px;
    border-radius: 12px;
    object-fit: cover;
  }
  
  .index-image img.thumbnail {
    transition: transform 0.3s ease;
    transform-origin: center center;
  }
  
  .index-image:hover img.thumbnail {
    transform: scale(1.1);
  }
  
  .pagination {
    margin: 60px 0 40px;
    text-align: center;
  }
  
  .page-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: inline-flex;
    gap: 8px;
  }
  
  .page-item {
    display: inline-block;
  }
  
  .page-link {
    display: inline-block;
    padding: 10px 16px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
    min-width: 40px;
    text-align: center;
  }
  
  /* 亮色模式 */
  .page-link {
    background-color: #f8f8f8;
    border: 1px solid #ddd;
    color: #333;
  }
  
  .page-link:hover {
    background-color: #e8e8e8;
    border-color: #ccc;
  }
  
  .page-link.active {
    background-color: #007bff;
    border-color: #007bff;
    color: #fff;
    font-weight: bold;
  }
  
  /* 暗黑模式 */
  html[data-theme="dark"] .page-link {
    background-color: #303030;
    border: 1px solid #3d3d3d;
    color: #999;
  }
  
  html[data-theme="dark"] .page-link:hover {
    background-color: #434343;
    border-color: #3a3a3a;
  }
  
  html[data-theme="dark"] .page-link.active {
    background-color: #505050;
    border-color: #4e4e4e;
    color: #fff;
    font-weight: 700;
  }
</style>
