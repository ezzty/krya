---
import BaseLayout from './BaseLayout.astro';
import NavBar from '../components/NavBar.astro';

interface Props {
  title: string;
  author: string;
  pubDate: string;
  wordCount?: number;
  tags?: string[];
  categories?: string[];
}

const { title, author, pubDate, wordCount = 0, tags = [], categories = [] } = Astro.props;

const formatDate = (date: string) => {
  return new Date(date).toISOString().split('T')[0];
};
---

<BaseLayout title={title}>
  <NavBar slot="header" />
  
  <div class="col-mb-12" id="main" role="main">
    <article class="post">
      <h1 class="col-mb-12 post-title">
        <a href={Astro.url.pathname}>{title}</a>
      </h1>
      <ul class="col-mb-12 post-meta">
        <li>作者：<a href="/about">{author}</a></li>
        <li>{formatDate(pubDate)}</li>
        <li>{wordCount}字</li>
      </ul>
      <div class="col-mb-12 post-content">
        <slot />
      </div>
      
      {(categories.length > 0 || tags.length > 0) && (
        <div class="post-meta-bottom">
          {categories.length > 0 && (
            <span class="meta-item">
              分类：{
                categories.map((category, index) => (
                  <>
                    {index > 0 && ', '}
                    <a href={`/categories/${encodeURIComponent(category)}`}>{category}</a>
                  </>
                ))
              }
            </span>
          )}
          {categories.length > 0 && tags.length > 0 && (
            <span class="meta-separator"> / </span>
          )}
          {tags.length > 0 && (
            <span class="meta-item">
              标签：{
                tags.map((tag, index) => (
                  <>
                    {index > 0 && ', '}
                    <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
                  </>
                ))
              }
            </span>
          )}
        </div>
      )}
    </article>
    
    <slot name="comments" />
  </div>
</BaseLayout>

<style>
.post-meta-bottom {
    margin-top: 40px;
    padding-top: 20px;
  color: #666;
  font-size: 0.95em;
  line-height: 2;
}
.meta-item a {
  color: #3354AA;
  text-decoration: none;
  transition: all 0.2s ease;
}
.meta-item a:hover {
  color: #1a3d8f;
  text-decoration: underline;
}
.meta-separator {
  color: #999;
  margin: 0 8px;
}
html[data-theme="dark"] .post-meta-bottom {
    color: #999;
  }
html[data-theme="dark"] .meta-item a {
  color: #5a8bff;
}
html[data-theme="dark"] .meta-item a:hover {
  color: #7aa5ff;
}
</style>
