---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts = await getCollection('posts');

const tagCount = new Map<string, number>();
posts.forEach(post => {
  const tags = post.data.tags || [];
  tags.forEach(tag => {
    tagCount.set(tag, (tagCount.get(tag) || 0) + 1);
  });
});

const tags = Array.from(tagCount.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="所有标签 | 浮生百记">
  <div class="container">
    <div class="col-mb-12">
      <h1 class="post-title">所有标签</h1>
      {tags.length > 0 ? (
        <div class="tag-cloud">
          {tags.map(([tag, count]) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-item">
              <span class="tag-name">{tag}</span>
              <span class="tag-count">{count}</span>
            </a>
          ))}
        </div>
      ) : (
        <p class="no-items">暂无标签</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .post-title { margin: 30px 0 20px; font-size: 1.5em; color: #4d4d4d; }
  .tag-cloud { display: flex; flex-wrap: wrap; gap: 12px; margin: 20px 0 40px; }
  .tag-item {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 16px; background-color: #f8f8f8;
    border-radius: 8px; text-decoration: none !important;
    transition: all 0.2s ease; border: 1px solid #eee;
  }
  .tag-item:hover { background-color: #3354AA; border-color: #3354AA; }
  .tag-item:hover .tag-name, .tag-item:hover .tag-count { color: #fff; }
  .tag-name { color: #4d4d4d; font-size: 1em; font-weight: 500; }
  .tag-count {
    color: #999; font-size: 0.85em; background-color: #eee;
    padding: 2px 8px; border-radius: 12px; min-width: 24px; text-align: center;
  }
  .no-items { color: #999; font-size: 1em; padding: 40px 0; text-align: center; }
  [data-theme="dark"] .post-title { color: #e0e0e0; }
  [data-theme="dark"] .tag-item { background-color: #2a2a2a; border-color: #3a3a3a; }
  [data-theme="dark"] .tag-name { color: #e0e0e0; }
  [data-theme="dark"] .tag-count { background-color: #3a3a3a; color: #999; }
  [data-theme="dark"] .tag-item:hover { background-color: #3354AA; border-color: #3354AA; }
</style>
