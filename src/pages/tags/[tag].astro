---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  
  const tagSet = new Set<string>();
  posts.forEach(post => {
    const tags = post.data.tags || [];
    tags.forEach(tag => tagSet.add(tag));
  });
  
  return Array.from(tagSet).map(tag => ({
    params: { tag },
    props: { tag }
  }));
}

const allPosts = await getCollection('posts');
const { tag } = Astro.params;
const decodedTag = decodeURIComponent(tag!);

const posts = allPosts
  .filter(post => {
    const tags = post.data.tags || [];
    return tags.includes(decodedTag);
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`标签：${decodedTag} | 浮生百记`}>
  <div class="container">
    <div class="col-mb-12">
      <h1 class="post-title">标签：{decodedTag}</h1>
      {posts.length > 0 ? (
        <div class="post-list">
          {posts.map(post => (
            <article class="post-item">
              <h2 class="post-title-small">
                <a href={`/post/${post.id}`}>{post.data.title}</a>
              </h2>
              <div class="post-meta">
                <span>{new Date(post.data.pubDate).toISOString().split('T')[0]}</span>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="no-posts">该标签下暂无文章</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .post-title { margin: 30px 0 20px; font-size: 1.5em; color: #4d4d4d; }
  .post-list { margin: 20px 0 40px; }
  .post-item { padding: 15px 0; border-bottom: 1px solid #eee; }
  .post-item:last-child { border-bottom: none; }
  .post-title-small { margin: 0 0 8px; font-size: 1.1em; }
  .post-title-small a { color: #4d4d4d; text-decoration: none !important; }
  .post-title-small a:hover { color: #3354AA; }
  .post-meta { color: #999; font-size: 0.9em; }
  .no-posts { color: #999; font-size: 1em; padding: 40px 0; text-align: center; }
  [data-theme="dark"] .post-title { color: #e0e0e0; }
  [data-theme="dark"] .post-item { border-bottom-color: #3a3a3a; }
  [data-theme="dark"] .post-title-small a { color: #e0e0e0; }
  [data-theme="dark"] .post-title-small a:hover { color: #5a8bff; }
</style>
