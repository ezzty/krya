---
import PostLayout from '../../layouts/PostLayout.astro';
import Twikoo from '../../components/Twikoo.astro';
import { getEntry, render, getCollection } from 'astro:content';
import { countWords } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  
  return posts.map((post) => ({
    params: {
      slug: post.id.replace('.md', ''),
    },
    props: {
      postId: post.id,
      wordCount: countWords(post.body || ''),
    },
  }));
}

const { postId, wordCount } = Astro.props;
const post = await getEntry('posts', postId);
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  author={post.data.author || 'Jin'}
  pubDate={post.data.pubDate.toISOString()}
  wordCount={wordCount}
  tags={post.data.tags || []}
  categories={post.data.categories || []}
>
  <Content />
  <Twikoo slot="comments" />
</PostLayout>
