---
import PostLayout from '../../layouts/PostLayout.astro';
import Twikoo from '../../components/Twikoo.astro';
import { getEntry, render, getCollection } from 'astro:content';
import { countWords, stripMarkdown } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter(post => !post.data.draft);
  
  return posts.map((post) => ({
    params: {
      slug: post.id.replace('.md', ''),
    },
    props: {
      postId: post.id,
      wordCount: countWords(post.body || ''),
      // 混合方案：优先使用 frontmatter 中的 description，没有则自动提取
      description: post.data.description || stripMarkdown(post.body || '').slice(0, 150),
    },
  }));
}

const { postId, wordCount, description } = Astro.props;
const post = await getEntry('posts', postId);
const { Content } = await render(post);
---

<PostLayout
  title={post.data.title}
  description={description}
  author={post.data.author || 'Jin'}
  pubDate={post.data.pubDate.toISOString()}
  wordCount={wordCount}
  tags={post.data.tags || []}
  categories={post.data.categories || []}
>
  <Content />
  <Twikoo slot="comments" />
</PostLayout>
